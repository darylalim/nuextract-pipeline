# Python
__pycache__/
*.pyc
.venv/

# Tool caches
.ruff_cache/
.pytest_cache/
.ty_cache/

# Secrets / env (.streamlit/config.toml is tracked; only secrets are ignored)
.env
.streamlit/secrets.toml

# OS / local
.DS_Store
.worktrees/
docs/

# Claude Code: share team hooks + project settings, keep personal settings local.
# Ignore the directory *contents* (not the dir) so specific paths can be negated —
# git can't re-include a file whose parent directory is excluded.
.claude/*
!.claude/settings.json
!.claude/hooks/
